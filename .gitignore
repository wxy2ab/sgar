# ---- Python 库标准 .gitignore ----
# 字节码 / 缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 打包 / 分发
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 单元测试 / 覆盖率
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.pytest_cache/
.hypothesis/

# 类型检查 / lint 缓存
.mypy_cache/
.dmypy.json
.ruff_cache/
.pyre/

# 虚拟环境
.venv/
venv/
env/
ENV/
.env

# 本地密钥 / 运行时产物（含真实密钥，切勿提交）
setting.ini
*.log
*.sqlite
*.sqlite3
*.db

# 编辑器 / 系统
.idea/
.vscode/
*.swp
.DS_Store
